---
import DropzoneIcon from "../assets/svg/dropzone.svg"
import HeroUnderline from "../assets/svg/hero-underline.svg"
import Footer from "./Footer.astro"
import { useTranslations } from "../i18n/ui"

const t = useTranslations(Astro.currentLocale)
---

<section id="stage-upload" class="stage-upload">
  <div class="stage-aurora" aria-hidden="true"></div>

  <div class="hero">
    <span class="hero-badge">
      <span class="hero-badge-dot"></span>
      {t.hero.badge}
    </span>
    <h1 class="hero-title">
      <span class="hero-word">{t.hero.titleSubtitles}</span>
      <span class="hero-word">{t.hero.titleFor}</span>
      <span class="hero-mark">
        <HeroUnderline class="hero-underline" />
        <span class="hero-mark-text" set:html={t.hero.titleAny} />
      </span>
    </h1>
    <p class="hero-sub">{t.hero.sub}</p>
  </div>

  <div
    id="dropzone"
    class="dropzone"
    role="button"
    tabindex="0"
    aria-label={t.hero.dropAria}
  >
    <input id="video-input" type="file" accept="video/*" hidden />
    <span class="dz-spotlight" aria-hidden="true"></span>
    <div class="dz-body">
      <span class="dz-icon-wrap">
        <span class="dz-pulse" aria-hidden="true"></span>
        <span class="dz-pulse dz-pulse--2" aria-hidden="true"></span>
        <DropzoneIcon class="dz-icon" />
      </span>
      <strong class="dz-label">{t.hero.dropLabel}</strong>
      <span class="dz-hint">{t.hero.dropHint}</span>
    </div>
  </div>

  <Footer />
</section>

<script>
  const dropzone = document.getElementById("dropzone")
  if (dropzone && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
    dropzone.addEventListener("pointermove", (event) => {
      const rect = dropzone.getBoundingClientRect()
      dropzone.style.setProperty("--mx", `${event.clientX - rect.left}px`)
      dropzone.style.setProperty("--my", `${event.clientY - rect.top}px`)
    })
  }
</script>
