---
import HeartIcon from "../assets/svg/heart.svg"
import GitHubIcon from "../assets/svg/github.svg"
import DollarIcon from "../assets/svg/dollar.svg"
import { languages, defaultLang, toLang } from "../i18n/ui"
import { useTranslations } from "../i18n/ui"

const t = useTranslations(Astro.currentLocale)
const current = toLang(Astro.currentLocale)
const localePath = (code: string) => (code === defaultLang ? "/" : `/${code}/`)
---

<footer class="upload-footer">
  <span class="footer-credit">
    {t.footer.developedBy}
    <a
      class="footer-link"
      href="https://midu.dev"
      target="_blank"
      rel="noopener noreferrer">midudev</a
    >
    {t.footer.with} <HeartIcon class="footer-heart" />
  </span>
  <a
    class="footer-repo"
    href="https://github.com/midudev/subvid.app"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={t.footer.repoAria}
  >
    <GitHubIcon class="footer-github" /> {t.footer.code}
  </a>
  <a
    class="footer-sponsor"
    href="https://github.com/sponsors/midudev"
    target="_blank"
    rel="noopener noreferrer"
  >
    <DollarIcon class="footer-sponsor-icon" /> {t.footer.sponsor}
  </a>
  <nav class="footer-lang" aria-label={t.footer.language}>
    {
      Object.entries(languages).map(([code, name]) => (
        <a
          class="footer-lang-link"
          href={localePath(code)}
          hreflang={code}
          data-locale={code}
          aria-current={code === current ? "true" : undefined}
        >
          {name}
        </a>
      ))
    }
  </nav>
</footer>

<script is:inline>
  // Persist an explicit language choice so the middleware stops auto-detecting
  // and respects the user's decision on future visits to the root.
  document.querySelectorAll(".footer-lang-link").forEach((link) => {
    link.addEventListener("click", () => {
      const code = link.getAttribute("data-locale")
      if (code)
        document.cookie = `locale=${code}; path=/; max-age=31536000; samesite=lax`
    })
  })
</script>
